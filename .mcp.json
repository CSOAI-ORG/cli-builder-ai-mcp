{
  "name": "cli-builder-ai-mcp",
  "description": "Cli Builder Ai automation via MCP. Includes generate argparse, generate click, parse help text. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_argparse",
      "description": "Generate Python argparse CLI boilerplate code.",
      "parameters": {
        "type": "object",
        "properties": {
          "program_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "arguments": {
            "type": "array"
          },
          "subcommands": {
            "type": "array"
          }
        },
        "required": [
          "program_name",
          "description",
          "arguments"
        ]
      }
    },
    {
      "name": "generate_click",
      "description": "Generate Python Click CLI boilerplate code.",
      "parameters": {
        "type": "object",
        "properties": {
          "program_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "commands": {
            "type": "array"
          }
        },
        "required": [
          "program_name",
          "description",
          "commands"
        ]
      }
    },
    {
      "name": "parse_help_text",
      "description": "Parse CLI help text output into structured command/option data.",
      "parameters": {
        "type": "object",
        "properties": {
          "help_text": {
            "type": "string"
          }
        },
        "required": [
          "help_text"
        ]
      }
    },
    {
      "name": "generate_manpage",
      "description": "Generate a man page in troff format.",
      "parameters": {
        "type": "object",
        "properties": {
          "program_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "synopsis": {
            "type": "string"
          },
          "options": {
            "type": "array"
          },
          "examples": {
            "type": "array"
          },
          "author": {
            "type": "string"
          }
        },
        "required": [
          "program_name",
          "description"
        ]
      }
    }
  ]
}